<!-- HALLUCIGENIA HALLU-C (Carbotubulus) MuJoCo Model
     25 leg-pairs / 8 valve zones, long-body squad leader
     Body: flexible segmented tube (Dragon Skin 10 analogue), 300mm / 26 segments
     Legs: stiffer actuated members (Dragon Skin 30 analogue)
     Valve zones: legs 1-3, 4-6, 7-9, 10-12, 13-15, 16-18, 19-21, 22-25
     Phase offset: pi/8 per zone

     Ref: Smith & Ortega-Hernandez 2014 Nature 514 (Hallucigenia)
          Manton 1950 J Linnean Soc (Peripatus locomotion)

     Carmen Mitchell / FAUNA -->
<mujoco model="hallu_c">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicit">
    <flag contact="enable"/>
  </option>

  <size nconmax="800" njmax="1600"/>

  <default>
    <default class="body_joint">
      <joint type="hinge" damping="0.015" stiffness="0.08" limited="true"
             range="-0.15 0.15"/>
    </default>
    <!-- lobopod legs: pitch axis (0 1 0) so legs swing fore/aft -->
    <default class="leg_joint">
      <joint type="hinge" axis="0 1 0" damping="0.005" stiffness="0.02"
             limited="true" range="-0.3 0.8"/>
    </default>
    <default class="leg_geom">
      <geom type="capsule" size="0.003" rgba="0.85 0.75 0.65 0.9"
            density="1100" friction="1.5 0.01 0.01" condim="4"
            contype="1" conaffinity="1"/>
    </default>
    <default class="body_geom">
      <geom type="capsule" rgba="0.9 0.8 0.7 0.85"
            density="1100" friction="0.8 0.01 0.01" condim="3"
            contype="1" conaffinity="1"/>
    </default>
    <default class="spine_geom">
      <geom type="capsule" size="0.001 0.008" rgba="0.95 0.5 0.9 0.7"
            contype="0" conaffinity="0"/>
    </default>
    <default class="pneumatic">
      <general gainprm="0.009" biasprm="0 -0.009 0" dyntype="filter" dynprm="0.06"/>
    </default>
  </default>

  <asset>
    <texture name="ground" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.6 0.55 0.5" rgb2="0.5 0.45 0.4"/>
    <material name="ground_mat" texture="ground" texrepeat="8 8"/>
  </asset>

  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.01" material="ground_mat"
          contype="1" conaffinity="1" friction="1.0 0.005 0.001"/>

